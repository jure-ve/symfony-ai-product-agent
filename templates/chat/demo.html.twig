{% extends 'base.html.twig' %}

{% block title %}Vanilla JS Chat - AI Product Agent{% endblock %}

{% block stylesheets %}
<style>
    body {
        font-family: 'Inter', sans-serif;
        background-color: #121212;
        color: #ffffff;
        margin: 0;
        padding: 0;
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
    }
    .chat-container {
        width: 100%;
        max-width: 600px;
        height: 80vh;
        background: #1e1e1e;
        border-radius: 16px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }
    .chat-header {
        background: #2A2A2A;
        padding: 20px;
        text-align: center;
        font-size: 1.2rem;
        font-weight: bold;
        border-bottom: 1px solid #333;
    }
    .chat-messages {
        flex: 1;
        padding: 20px;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 15px;
    }
    .message {
        max-width: 80%;
        padding: 12px 16px;
        border-radius: 12px;
        line-height: 1.5;
        word-wrap: break-word;
    }
    .message.user {
        align-self: flex-end;
        background: #007BFF;
        color: white;
        border-bottom-right-radius: 2px;
    }
    .message.ai {
        align-self: flex-start;
        background: #333333;
        color: #E0E0E0;
        border-bottom-left-radius: 2px;
    }
    .chat-input {
        display: flex;
        padding: 20px;
        background: #2A2A2A;
        border-top: 1px solid #333;
    }
    .chat-input input {
        flex: 1;
        padding: 12px 20px;
        border: none;
        border-radius: 24px;
        background: #404040;
        color: white;
        font-size: 1rem;
        outline: none;
    }
    .chat-input button {
        background: #007BFF;
        color: white;
        border: none;
        padding: 0 20px;
        margin-left: 10px;
        border-radius: 24px;
        cursor: pointer;
        font-weight: bold;
        transition: 0.2s;
    }
    .chat-input button:hover {
        background: #0056b3;
    }
    .chat-input button:disabled {
        background: #555;
        cursor: not-allowed;
    }
</style>
{% endblock %}

{% block body %}
<div class="chat-container">
    <div class="chat-header">
        Agente de Productos
    </div>
    <div class="chat-messages" id="chat">
        <div class="message ai">¡Hola! Soy tu asistente de tienda. ¿En qué puedo ayudarte hoy?</div>
    </div>
    <div class="chat-input border-top">
        <input type="text" id="prompt" placeholder="Escribe tu mensaje..." autocomplete="off">
        <button id="btn-send">Enviar</button>
    </div>
</div>

<script>
    const chatContainer = document.getElementById('chat');
    const inputPrompt = document.getElementById('prompt');
    const btnSend = document.getElementById('btn-send');

    btnSend.addEventListener('click', sendMessage);
    inputPrompt.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') sendMessage();
    });

    async function sendMessage() {
        const text = inputPrompt.value.trim();
        if (!text) return;

        // Añadir mensaje del usuario
        addMessageBubble(text, 'user');
        inputPrompt.value = '';
        inputPrompt.disabled = true;
        btnSend.disabled = true;

        // Crear burbuja inicial para la IA
        let aiBubble = addMessageBubble('⏳ Pensando...', 'ai');

        try {
            const response = await fetch('/api/chat', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ question: text })
            });

            const data = await response.json();
            
            // Limpiamos el texto de espera
            aiBubble.innerHTML = '';
            
            if (!response.ok) {
                // Muestra un error si lo hay en la respuesta JSON
                aiBubble.innerHTML = `<span style="color: #ff6b6b">${escapeHTML(data.error || 'Error desconocido del servidor.')}</span>`;
            } else {
                // Simulamos el efecto visual de "escribiendo..." en JavaScript
                const words = data.answer.split(' ');
                let currentText = '';
                
                for (let word of words) {
                    currentText += word + ' ';
                    // Escapamos el contenido para evitar XSS y luego convertimos Newlines a BR
                    aiBubble.innerHTML = escapeHTML(currentText).replace(/\n/g, '<br>');
                    chatContainer.scrollTop = chatContainer.scrollHeight;
                    await new Promise(r => setTimeout(r, 30));
                }
            }
        } catch (error) {
            console.error("Fetch Error:", error);
            aiBubble.innerHTML = `<span style="color: #ff6b6b">[Error de red] No se pudo conectar al servidor.</span>`;
        } finally {
            inputPrompt.disabled = false;
            btnSend.disabled = false;
            inputPrompt.focus();
        }
    }

    function escapeHTML(str) {
        const p = document.createElement('p');
        p.textContent = str;
        return p.innerHTML;
    }

    function addMessageBubble(text, type) {
        const div = document.createElement('div');
        div.className = `message ${type}`;
        div.innerText = text;
        chatContainer.appendChild(div);
        chatContainer.scrollTop = chatContainer.scrollHeight;
        return div;
    }
</script>
{% endblock %}
